<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="boardApp.mapper.LoginMapper">

    <select id="selectLoginUser" parameterType="boardApp.VO.UserVO"
        resultType="boardApp.VO.UserVO">
        SELECT user_no, user_id, user_pw, user_name, user_authority, user_enabled
        FROM tb_user
        WHERE user_id = #{userId}
    </select>

</mapper>